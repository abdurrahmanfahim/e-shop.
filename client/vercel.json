{
  "rewrites": [
    { 
      "source": "/(.*)",
      "destination": "/index.html" 
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        },
        {
          "key": "Permissions-Policy",
          "value": "web-share=()"
        }
      ]
    }
  ]
}
